version: '3.8'

services:
  repo-image-service:
    build: 
      # Specify the GitHub URL as the context
      context: https://github.com 
      # Optional: specify the path to the Dockerfile if it's not in the root
      dockerfile: path/to/Dockerfile 
    image: your-username/repo-image:latest
    ports:
      - "8000:5000"
